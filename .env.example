# Whale Tracker Pro v4.5 Environment Variables
# Create a .env file or export these in your shell

# Required for Telegram signals
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Required for Expert Intelligence (win rate tracking)
MORALIS_API_KEY=your_moralis_key_here

# Optional: Explorer API Keys for higher rate limits
ETHERSCAN_KEY=your_etherscan_key_here
BSCSCAN_KEY=your_bscscan_key_here
